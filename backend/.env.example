# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# REQUIRED in production: use a long random string (32+ chars)
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Frontend URL for CORS (set to your domain in production)
FRONTEND_URL=http://localhost:5173

# SQLite database path (Docker: set to /app/data/candsync.db)
DB_PATH=

# ─── AI API Keys (add at least one to enable AI resume extraction) ────────────
# Google Gemini  →  https://aistudio.google.com  → Get API Key
GEMINI_API_KEY=

# OpenRouter     →  https://openrouter.ai  → Keys → Create Key
OPENROUTER_API_KEY=
